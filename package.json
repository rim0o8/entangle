{
  "name": "entangle",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "The channel between agents. Where humans can't speak.",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts",
    "example:doubleyes": "tsx examples/double-yes.ts",
    "example:quietbroadcast": "tsx examples/quiet-broadcast.ts",
    "demo:doubleyes": "tsx src/demo/cli.ts --scenario=double-yes",
    "demo:quietbroadcast": "tsx src/demo/cli.ts --scenario=quiet-broadcast",
    "lint": "biome check .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "better-sqlite3": "^11.7.0",
    "dotenv": "^16.4.7",
    "nanoid": "^5.0.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ws": "^8.18.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
