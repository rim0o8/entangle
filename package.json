{
  "name": "entangle",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "The channel between agents. Agent-to-agent communication between two humans' AI agents, built on Photon Spectrum.",
  "scripts": {
    "dev": "bun run src/runtime/dev.ts",
    "test": "HUMANIZE_STUB=1 ANTHROPIC_API_KEY= bun test",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "agent": "bun run src/runtime/agent.ts",
    "example:doubleyes": "bun run examples/double-yes.ts",
    "example:quietbroadcast": "bun run examples/quiet-broadcast.ts",
    "tail-events": "bun run src/runtime/tail-events.ts",
    "smoke:imessage": "bun run scripts/smoke-imessage.ts",
    "seed": "bun run src/engram/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "nanoid": "^5.0.0",
    "picocolors": "^1.1.0",
    "spectrum-ts": "^0.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.1.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
